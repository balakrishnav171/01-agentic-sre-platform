# ============================================================
# SRE Agent Platform — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_ACCOUNT_ID=123456789012
EKS_CLUSTER_NAME=sre-platform-eks

# Azure Configuration
AZURE_SUBSCRIPTION_ID=your_azure_subscription_id
AZURE_TENANT_ID=your_azure_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_RESOURCE_GROUP=sre-platform-rg
AKS_CLUSTER_NAME=sre-platform-aks

# Datadog Configuration
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key
DATADOG_SITE=datadoghq.com

# ServiceNow Configuration
SERVICENOW_INSTANCE_URL=https://your-instance.service-now.com
SERVICENOW_USERNAME=your_servicenow_username
SERVICENOW_PASSWORD=your_servicenow_password

# BigPanda Configuration
BIGPANDA_API_TOKEN=your_bigpanda_api_token
BIGPANDA_APP_KEY=your_bigpanda_app_key

# ChromaDB Configuration
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=sre_runbooks

# Application Configuration
LOG_LEVEL=INFO
ENVIRONMENT=development
DEBUG=false
API_PORT=8000

# MCP Server Ports
K8S_MCP_PORT=8001
AWS_MCP_PORT=8002
AZURE_MCP_PORT=8003
SNOW_MCP_PORT=8004
